[physics]

3d/physics_engine="GodotPhysics3D"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_s3tc_bptc=true
textures/vram_compression/import_etc2_astc=true
textures/vram_compression/compress_with_gpu=false
lights_and_shadows/directional_shadow/soft_shadow_filter_quality=1
lights_and_shadows/directional_shadow/soft_shadow_filter_quality.mobile=1
lights_and_shadows/positional_shadow/soft_shadow_filter_quality=1
lights_and_shadows/positional_shadow/soft_shadow_filter_quality.mobile=1
reflections/sky_reflections/ggx_samples=16
reflections/reflection_atlas/reflection_size=128
global_illumination/gi/use_half_resolution=true
shading/overrides/force_vertex_shading=true
shading/overrides/force_lambert_over_burley=true
textures/default_filters/use_nearest_mipmap_filter=true
textures/default_filters/anisotropic_filtering_level=0
camera/depth_of_field/depth_of_field_bokeh_shape=0
camera/depth_of_field/depth_of_field_bokeh_quality=0
environment/ssao/quality=0
environment/ssao/adaptive_target=0.0
environment/ssil/quality=0
environment/ssil/adaptive_target=0.0
anti_aliasing/screen_space_roughness_limiter/enabled=false
anti_aliasing/quality/smaa_edge_detection_threshold=0.01
textures/default_filters/texture_mipmap_bias=-0.25
environment/glow/upscale_mode=0
global_illumination/sdfgi/frames_to_converge=3
environment/volumetric_fog/use_filter=0
anti_aliasing/quality/screen_space_aa=2
occlusion_culling/use_occlusion_culling=true
viewport/canvas_textures/default_texture_filter=1
environment/mode.macos=0
environment/mode=2
environment/scale=1.0
